# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=your_sanity_token
# Sanity webhook → instant content updates (see app/api/revalidate/route.ts
# for full setup instructions). Generate with: openssl rand -hex 32
SANITY_REVALIDATE_SECRET=your_random_secret_here
# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Formspree
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your_form_id

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=your_pixel_id

# Site
NEXT_PUBLIC_SITE_URL=https://allwinmachinery.com
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210
NEXT_PUBLIC_PHONE_NUMBER=+919876543210

# ── Upstash Redis (Rate Limiter) ──────────────────────────────────────────

UPSTASH_REDIS_KV_REST_API_URL=
UPSTASH_REDIS_KV_REST_API_TOKEN=